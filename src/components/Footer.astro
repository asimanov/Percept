---
const today = new Date();
---

<style>
    footer {
        width: 100%;
        
        ul {
            list-style-type: none;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            margin: 0;
            padding: 0;

            li {
                a {
                    border: none;

                    &::after {
                        display: none;
                    }
                }
            }
        }
    }
</style>

<footer>
    <section class="footer-note-contact">
        <div class="row">
            <div class="col-12 p-t-3">
                <ul>
                    <li><a href="https://cara.app/antonsimanov" target="_blank" rel="noopener noreferrer" title="Anton Simanov on Cara"><i class="fa-solid fa-c"></i></a></li>
                    <li><a href="https://bsky.app/profile/antonsimanov.bsky.social" target="_blank" rel="noopener noreferrer" title="Anton Simanov on Bluesky"><i class="fa-brands fa-bluesky"></i></a></li>
                    <li><a href="https://www.instagram.com/antonsimanov/" target="_blank" rel="noopener noreferrer" title="Anton Simanov on Instagram"><i class="fa fa-instagram" aria-hidden="true"></i></a></li>
                    <li><a href="https://www.threads.com/@antonsimanov" target="_blank" rel="noopener noreferrer" title="Anton Simanov on Threads"><i class="fa-brands fa-threads"></i></a></li>
                    <li><a href="https://www.facebook.com/antonsimanov" target="_blank" rel="noopener noreferrer" title="Anton Simanov on Facebook"><i class="fa-brands fa-facebook"></i></a></li>
                    <li><a href="https://x.com/AntonSimanov" target="_blank" rel="noopener noreferrer" title="Anton Simanov on X (formerly Twitter)"><i class="fa-brands fa-x-twitter" aria-hidden="true"></i></a></li>
                </ul>                    
            </div>
        </div>
    </section>

    <section class="footer-note">
        <div class="row">
            <div class="col-12 p-t-1">
                <p class="m-0 font-size--sm">Built with <a href="https://simanov.dev/baseline/" title="Baseline Library" target="_blank" rel="noopener noreferrer">Baseline Library</a> and some elbow grease.</p>
                <p class="m-0 font-size--sm">Powered by an open source, JS templating, markdown driven website builder. Deal with it 🕶️</p>
                
            </div>
        </div>
    </section>

    <section>
        <div class="row">
            <div class="col-xs-12 col-md-6 p-y-1 font-size--sm">
                <i class="fad fa-copyright" aria-hidden="true"></i>
                <span>{today.getFullYear()}</span>
                <span>Anton Simanov</span>
            </div>
        </div>
    </section>
</footer>